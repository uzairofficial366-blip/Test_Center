# Copy this file to .env and fill in your values

# MongoDB Atlas connection string (REQUIRED for production)
# Get this from: https://cloud.mongodb.com -> Your Cluster -> Connect -> Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/edutest?retryWrites=true&w=majority

# JWT Secret – use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here

# Port (Vercel ignores this, only used locally)
PORT=5000
